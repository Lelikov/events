# ============================================================================
# Root .env for the full docker-compose stack (cp .env.example .env to edit).
#
# Every value below matches the inline default in docker-compose.yml, so the
# stack runs WITHOUT a .env file at all. Copy + edit only what you change.
#
# Dev secrets are deliberately >=16 chars and placeholder-free: event-receiver
# and event-admin refuse weak/placeholder secrets outside DEBUG.
# NEVER use these values outside local development.
# ============================================================================

# ---------------------------------------------------------------------------
# Global
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Published host ports (uncomment to override; values below are the defaults).
# rabbitmq / pg-calcom / mocks stay bound to 127.0.0.1 regardless of the port.
# CORS origins, MEETING_HOST_URL and VITE_WEBHOOK_URL defaults follow these
# vars automatically (compose nests them into the URL defaults).
# ---------------------------------------------------------------------------
#RECEIVER_PORT=8888
#USERS_PORT=8001
#ADMIN_PORT=8002
#ADMIN_FRONTEND_PORT=3000
#JITSI_CHAT_PORT=8080
#RABBITMQ_AMQP_PORT=5672
#RABBITMQ_MGMT_PORT=15672
#PG_CALCOM_PORT=5433
#MOCKS_PORT=8089
#PROMETHEUS_PORT=9090
#GRAFANA_PORT=3001
#ALERTMANAGER_PORT=9093

# Observability (Prometheus, Grafana, Alertmanager, postgres exporters) lives in
# the "observability" compose profile and is OFF by default. Start it on demand
# with `docker compose --profile observability up -d`, or uncomment the line
# below to make it part of the default `docker compose up`.
#COMPOSE_PROFILES=observability

# ---------------------------------------------------------------------------
# RabbitMQ (guest/guest only works on localhost — containers need a real user)
# ---------------------------------------------------------------------------
RABBITMQ_USER=events
RABBITMQ_PASSWORD=dev-rabbit-password-01

# ---------------------------------------------------------------------------
# PostgreSQL containers
# ---------------------------------------------------------------------------
PG_SAVER_USER=postgres
PG_SAVER_PASSWORD=postgres
PG_SAVER_DB=event_saver

PG_USERS_USER=postgres
PG_USERS_PASSWORD=postgres
PG_USERS_DB=event_users

PG_NOTIFIER_USER=postgres
PG_NOTIFIER_PASSWORD=postgres
PG_NOTIFIER_DB=event_notifier

PG_CALCOM_USER=calcom
PG_CALCOM_PASSWORD=calcom
PG_CALCOM_DB=calcom

# ---------------------------------------------------------------------------
# cal.com database used by event-booking.
# Default: the pg-calcom fixture container (schema/seed in docker/calcom-init).
# Point at a real cal.com instance to integrate with an external deployment;
# the pg-calcom container is then simply unused.
# ---------------------------------------------------------------------------
CALCOM_DATABASE_URL=postgresql+asyncpg://calcom:calcom@pg-calcom:5432/calcom

# Signature secret for POST /event/calcom webhooks (X-Cal-Signature-256).
# Must equal the secret configured on the cal.com webhook subscription.
CALCOM_WEBHOOK_SECRET=dev-calcom-webhook-9d2c4f7a1e6b8350

# ---------------------------------------------------------------------------
# Cross-service API keys (each value must match on both sides; compose wires
# them everywhere they are needed)
# ---------------------------------------------------------------------------
# event-booking -> event-receiver POST /event/booking
BOOKING_API_KEY=dev-booking-api-key-7f3a9c1e24b85d60
# event-admin & event-notifier -> event-receiver POST /event/admin
ADMIN_API_KEY=dev-admin-api-key-4e8b2f6a91c73d50
# Static bearer for event-users' API (receiver, admin, notifier all use it)
USERS_API_BEARER_TOKEN=dev-users-bearer-2a7d9e4f8c1b6350
# JWTs minted by event-admin, verified by event-users
ADMIN_JWT_SECRET=dev-admin-jwt-8f2c6a1d9e4b7350a3c5d7e9
# event-users -> event-admin cache invalidation
CACHE_INVALIDATION_TOKEN=dev-cache-invalidation-3e9f1c7b4a82d650
# UniSender Go inbound webhook auth (POST /event/unisender-go)
EMAIL_API_KEY=dev-unisender-webhook-5c1f8e3b7a92d460

# ---------------------------------------------------------------------------
# Jitsi meeting JWTs (minted by event-booking, verified by event-receiver on
# POST /event/jitsi — secret/issuer/audience must stay in sync)
# ---------------------------------------------------------------------------
JITSI_JWT_SECRET=dev-jitsi-jwt-5b8e2d9c4f7a1360
JITSI_JWT_AUD=jitsi
JITSI_JWT_ISS=event-booking
JITSI_JWT_SUB=meet.jit.si
# Public URL participants open for meetings (the jitsi-chat SPA)
MEETING_HOST_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# GetStream Chat (shared by event-booking, event-receiver and jitsi-chat).
# Default CHAT_BASE_URL points at the WireMock container; set the real
# endpoint + real key/secret to talk to GetStream.
# ---------------------------------------------------------------------------
CHAT_API_KEY=devgetstreamkey0123456789
CHAT_API_SECRET=devgetstreamapisecret0123456789
CHAT_USER_ID_ENCRYPTION_KEY=devchatencryption6b2e9d4c8f1a7350
CHAT_BASE_URL=http://mocks:8080/getstream
# Browser-side GetStream endpoint for the jitsi-chat SPA (the browser cannot
# resolve the in-network mock, so the real endpoint is the default)
VITE_STREAM_CHAT_BASE_URL=https://chat.stream-io-api.com

# ---------------------------------------------------------------------------
# Shortify URL shortener (event-booking). Mock by default.
# ---------------------------------------------------------------------------
SHORTENER_URL=http://mocks:8080/shortify
SHORTENER_API_KEY=dev-shortify-api-key-8c4e1f7b2a93d650

# ---------------------------------------------------------------------------
# event-booking
# ---------------------------------------------------------------------------
IS_ENABLE_BOOKING_CONSTRAINTS=false

# Booking blacklist: event-booking reads the active set from event-admin
# (GET /api/blacklist/active, EVENT_ADMIN_API_URL=http://event-admin:8888 is
# wired in docker-compose.yml). The token is shared by event-admin (validates)
# and event-booking (sends). Fail-open: booking keeps working if admin is down.
BLACKLIST_ENABLED=true
BLACKLIST_SERVICE_TOKEN=dev-blacklist-service-9d4f2c7b1e8a6350
BLACKLIST_CACHE_TTL=300

# ---------------------------------------------------------------------------
# event-notifier: UniSender Go + Telegram. Mocks by default.
# UNISENDER_TEMPLATE_IDS is hardcoded in docker-compose.yml (compose
# ${VAR:-default} interpolation cannot carry JSON braces) — override real
# template UUIDs via a docker-compose.override.yml.
# ---------------------------------------------------------------------------
UNISENDER_BASE_URL=http://mocks:8080/unisender
UNISENDER_API_KEY=dev-unisender-api-key-6e2c9f4b8a13d750
UNISENDER_FROM_EMAIL=noreply@dev.local
UNISENDER_FROM_NAME=Events Dev
TELEGRAM_BASE_URL=http://mocks:8080/telegram
TELEGRAM_BOT_TOKEN=0000000000:dev-telegram-bot-token-mock

# ---------------------------------------------------------------------------
# event-users: external CRM (sync/webhook disabled in the local stack;
# CRM_ENCRYPTION_KEY must be 64 hex chars = AES-256)
# ---------------------------------------------------------------------------
CRM_API_URL=http://mocks:8080/crm
CRM_API_TOKEN=dev-crm-api-token-1c7e4f9b2a83d650
CRM_ENCRYPTION_KEY=9f1e8d7c6b5a49382716059483726150aabbccddeeff00112233445566778899

# ---------------------------------------------------------------------------
# Observability: Grafana dev login (Prometheus needs no credentials).
# Dashboards: http://localhost:3001 (System Overview + Booking Flow,
# provisioned from docker/grafana/dashboards/).
# ---------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ---------------------------------------------------------------------------
# Ops alerting (Alertmanager -> Telegram). DEDICATED ops bot/chat, separate
# from event-notifier's client-facing TELEGRAM_BOT_TOKEN.
#
# Left blank by default => graceful degrade: Alertmanager loads with a fake
# token/chat (entrypoint defaults) and stays up; alerts still fire and route,
# but Telegram sends fail (logged by Alertmanager). For REAL delivery, create
# an ops bot via @BotFather, get the target chat id, and set both below.
#   - ALERT_TELEGRAM_BOT_TOKEN: "<id>:<secret>" from BotFather
#   - ALERT_TELEGRAM_CHAT_ID:   numeric chat id (negative for group chats)
# Alertmanager UI: http://localhost:9093 (loopback only).
# ---------------------------------------------------------------------------
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=

# ---------------------------------------------------------------------------
# Frontends
# ---------------------------------------------------------------------------
# Empty = same-origin: nginx in event-admin-frontend proxies API calls to
# event-admin. Set e.g. http://localhost:8002 to bypass the proxy.
VITE_API_BASE_URL=
VITE_JITSI_DOMAIN=meet.jit.si
VITE_WEBHOOK_URL=http://localhost:8888/event/jitsi
